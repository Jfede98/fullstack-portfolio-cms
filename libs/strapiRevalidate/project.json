{
  "name": "@sitio-publico/strapi-revalidate",
  "root": "libs/strapiRevalidate",
  "version": "1.0.0",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "libs/strapiRevalidate",
        "parallel": false,
        "command": "strapi-plugin build"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/strapiRevalidate",
        "command": "strapi-plugin watch"
      }
    },
    "verify": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/strapiRevalidate",
        "command": "strapi-plugin verify"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/strapiRevalidate",
        "command": "echo 'no action defined'"
      },
      "dependsOn": ["build"]
    },
    "test:ts:front": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/strapiRevalidate",
        "command": "run -T tsc -p admin/tsconfig.json"
      }
    },
    "test:ts:back": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/strapiRevalidate",
        "command": "run -T tsc -p server/tsconfig.json"
      }
    },
    "watch:link": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/strapiRevalidate",
        "command": "strapi-plugin watch:link"
      }
    }
  }
}
