# ===========================================
# Frontend Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# Strapi Connection
STRAPI_ADMIN_TOKEN=your_strapi_admin_api_token_here
STRAPI_API_URL=http://localhost:1337
STRAPI_ORIGIN_HEADER=http://localhost:4009

# Site
SITE_ORIGIN=http://localhost:4009
URL_STATIC_RESOURCES=http://localhost:1337

# Analytics (optional)
GOOGLE_TAG_MANAGER_ID=

# Revalidation
REVALIDATE_TOKEN=your_revalidate_token_here

# SST Deploy (optional - only for AWS deployment)
# SST_APP_NAME=my-portfolio
# SST_REGION=us-east-1
# SST_DOMAIN=
# SST_DOMAIN_CERT=
# SST_VPC_ID=
# SST_VPC_REGION=
# SST_VPC_SECURITY_GROUPS=
# SST_VPC_SUBNET_IDS=
# SST_ARN_WAF=
# AWS_S3_ROOT_PATH=
