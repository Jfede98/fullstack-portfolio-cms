{
  "kind": "collectionType",
  "collectionName": "custom_icons",
  "info": {
    "singularName": "custom-icon",
    "pluralName": "custom-icons",
    "displayName": "CustomIcon"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "customField",
      "customField": "plugin::dynamic-enumeration.dynamic-field"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
