{
  "kind": "collectionType",
  "collectionName": "faq_categories",
  "info": {
    "singularName": "faq-category",
    "pluralName": "faq-categories",
    "displayName": "FAQ Category",
    "description": "Categories for organizing FAQ items"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}